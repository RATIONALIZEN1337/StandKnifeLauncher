<Window x:Class="StandKnifeLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="StandKnife Launcher" 
        Height="800" Width="1100"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <Color x:Key="ColorBg">#1E1E22</Color>
        <Color x:Key="ColorSurface">#2B2A30</Color>
        <Color x:Key="ColorBorder">#3E3C45</Color>
        <Color x:Key="ColorText">#E4E4E7</Color>
        <Color x:Key="ColorAccent">#D0BFFF</Color>
        <Color x:Key="ColorAccentText">#1E1E22</Color>

        <Color x:Key="ColorTooltipBg">#36343F</Color>

        <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource ColorBg}" />
        <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="{StaticResource ColorSurface}" />
        <SolidColorBrush x:Key="MaterialDesignBody" Color="{StaticResource ColorText}" />
        <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource ColorAccent}" />
        <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="{StaticResource ColorAccentText}" />
        <SolidColorBrush x:Key="MaterialDesignTextBoxBorder" Color="{StaticResource ColorBorder}" />
        <SolidColorBrush x:Key="MaterialDesignDivider" Color="{StaticResource ColorBorder}" />

        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D4FF"/>
                    <Setter Property="Foreground" Value="#1E1E22"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A08CFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль тултипов с переносом текста -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#36343F"/>
            <Setter Property="Foreground" Value="#E4E4E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4F4D59"/>
            <Setter Property="Placement" Value="Top"/>
            <Setter Property="VerticalOffset" Value="-8"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="280" LineHeight="18" FontSize="13"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,8,8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="12" ShadowDepth="4" Direction="320"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна -->
            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="0,16" Background="{DynamicResource MaterialDesignCardBackground}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="GamepadVariant" Width="26" Height="26" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="StandKnife Launcher" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Основной контент -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
                <StackPanel MaxWidth="1050" HorizontalAlignment="Center">

                    <!-- ПУТЬ К ИГРЕ (На всю ширину) -->
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <materialDesign:PackIcon Kind="Folder" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Путь к игре" Style="{StaticResource SectionHeaderStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TextGamePath" Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Foreground="{DynamicResource MaterialDesignBody}" Padding="16,14" IsReadOnly="True" Text="C:\Users\ksn\Downloads\StandKnife 3.1\StandKnife.exe" ToolTip="Укажите путь к исполняемому файлу игры. Поддерживаются только .exe файлы."/>
                                <Button x:Name="BtnBrowse" Grid.Column="2" Click="BtnBrowse_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" Padding="24,0" Height="Auto" materialDesign:ButtonAssist.CornerRadius="8" ToolTip="Нажмите, чтобы открыть проводник и выбрать файл игры.">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="22" Height="22"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="12*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="10*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <materialDesign:PackIcon Kind="Monitor" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Графика" Style="{StaticResource SectionHeaderStyle}"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="DirectX" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboApi" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="DX11 — стандартный стабильный движок игры. DX12 — скрытый экспериментальный движок для новых видеокарт.">
                                                <ComboBoxItem Content="DirectX 11" IsSelected="True"/>
                                                <ComboBoxItem Content="DirectX 12"/>
                                                <ComboBoxItem Content="По умолчанию"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="Разрешение" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboResolution" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="Разрешение экрана в игре. Уменьшение разрешения сильно повышает производительность.">
                                                <ComboBoxItem Content="1920x1080 (Full HD)" IsSelected="True"/>
                                                <ComboBoxItem Content="1280x720 (HD)"/>
                                                <ComboBoxItem Content="Нативное"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="Качество" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboQuality" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="Общее качество графики (тени, текстуры, эффекты). Влияет на загрузку видеокарты.">
                                                <ComboBoxItem Content="Минимальное"/>
                                                <ComboBoxItem Content="Низкое"/>
                                                <ComboBoxItem Content="Простое"/>
                                                <ComboBoxItem Content="Хорошее" IsSelected="True"/>
                                                <ComboBoxItem Content="Красивое"/>
                                                <ComboBoxItem Content="Фантастическое"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="2">
                                            <TextBlock Text="VSync" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboVSync" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="Вертикальная синхронизация убирает разрывы картинки, но может добавить небольшую задержку управления (input-lag).">
                                                <ComboBoxItem Content="Включен" IsSelected="True"/>
                                                <ComboBoxItem Content="Отключен"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="0">
                                            <TextBlock Text="FPS лимит" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboFpsLimit" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" IsEditable="True" ToolTip="Ограничение максимального количества кадров. Защищает видеокарту от перегрева. Можно ввести свое значение.">
                                                <ComboBoxItem Content="Без ограничений" IsSelected="True"/>
                                                <ComboBoxItem Content="60 FPS"/>
                                                <ComboBoxItem Content="120 FPS"/>
                                                <ComboBoxItem Content="144 FPS"/>
                                                <ComboBoxItem Content="240 FPS"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="2">
                                            <TextBlock Text="Режим окна" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboWindowMode" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="Полноэкранный режим обеспечивает максимальную производительность.">
                                                <ComboBoxItem Content="Полноэкранный" IsSelected="True"/>
                                                <ComboBoxItem Content="Оконный"/>
                                                <ComboBoxItem Content="Безрамочный"/>
                                                <ComboBoxItem Content="Эксклюзивный полный экран" ToolTip="Блокирует вмешательство Windows (DWM). Максимальный FPS и минимальная задержка мыши."/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <materialDesign:PackIcon Kind="Speedometer" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Производительность" Style="{StaticResource SectionHeaderStyle}"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Режим процессора" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboCpu" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" SelectionChanged="ComboCpu_SelectionChanged" ToolTip="Отключение E-ядер (энергоэффективных) может избавить от микрофризов в тяжелых сценах.">
                                                <ComboBoxItem Content="Все ядра" IsSelected="True"/>
                                                <ComboBoxItem Content="Только физ. ядра"/>
                                                <ComboBoxItem Content="Вручную"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Приоритет процесса" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox x:Name="ComboPriority" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="12,10" ToolTip="Высокий приоритет заставляет систему выделять игре максимум ресурсов Windows.">
                                                <ComboBoxItem Content="Обычный"/>
                                                <ComboBoxItem Content="Высокий" IsSelected="True"/>
                                                <ComboBoxItem Content="В реальном времени"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel x:Name="PanelCoreSelection" Visibility="Collapsed" Margin="0,20,0,0">
                                        <TextBlock Text="ВЫБОР ЯДЕР" Style="{StaticResource LabelStyle}"/>
                                        <Border Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16">
                                            <WrapPanel x:Name="CoresWrapPanel" HorizontalAlignment="Left" ToolTip="Выберите конкретные ядра для обработки игры.">
                                                <WrapPanel.Resources>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Setter Property="Margin" Value="0,8,24,8"/>
                                                        <Setter Property="FontSize" Value="14"/>
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                    </Style>
                                                </WrapPanel.Resources>
                                            </WrapPanel>
                                        </Border>
                                    </StackPanel>

                                    <CheckBox x:Name="CheckGcIncremental" Content="Инкрементальный GC (-gc-incremental)" Margin="0,20,0,0" FontSize="14" FontWeight="Medium" ToolTip="Разбивает процесс очистки памяти Unity на мелкие части. Кардинально уменьшает количество фризов и подтормаживаний."/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <materialDesign:PackIcon Kind="Flash" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Быстрые пресеты" Style="{StaticResource SectionHeaderStyle}"/>
                                    </StackPanel>
                                    <UniformGrid Columns="2" Rows="2">
                                        <Button x:Name="BtnFastStart" Click="BtnFastStart_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" materialDesign:ButtonAssist.CornerRadius="8" Height="68" Margin="0,0,6,6" ToolTip="Оптимальные настройки для выжимания максимального количества кадров в секунду.">
                                            <StackPanel>
                                                <TextBlock Text="Макс. FPS" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Приоритет" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnMaxFps" Click="BtnMaxFps_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" materialDesign:ButtonAssist.CornerRadius="8" Height="68" Margin="6,0,0,6" ToolTip="Отключает энергоэффективные ядра. Применяется для идеально плавной картинки без задержек.">
                                            <StackPanel>
                                                <TextBlock Text="Без фризов" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Физ. ядра" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnDx12" Click="BtnDx12_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" materialDesign:ButtonAssist.CornerRadius="8" Height="68" Margin="0,6,6,0" ToolTip="Активация скрытого экспериментального движка DX12 для новых видеокарт.">
                                            <StackPanel>
                                                <TextBlock Text="Эксперимент" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Скрытый DX12" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnDx11" Click="BtnDx11_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" materialDesign:ButtonAssist.CornerRadius="8" Height="68" Margin="6,6,0,0" ToolTip="Стабильный стандартный запуск на проверенном движке DX11.">
                                            <StackPanel>
                                                <TextBlock Text="Стандарт" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Обычный DX11" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <materialDesign:PackIcon Kind="Cogs" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Система и Питание" Style="{StaticResource SectionHeaderStyle}"/>
                                    </StackPanel>

                                    <TextBlock Text="ЭНЕРГОПОТРЕБЛЕНИЕ" Style="{StaticResource LabelStyle}"/>
                                    <Border Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,16" ToolTip="Выбор профиля электропитания под ваше устройство.">
                                        <UniformGrid Columns="2">
                                            <RadioButton x:Name="RadioPC" Content="🖥️ ПК (Макс)" GroupName="PowerMode" IsChecked="True" Style="{StaticResource MaterialDesignTabRadioButton}" Height="36" FontSize="13" FontWeight="Medium"/>
                                            <RadioButton x:Name="RadioLaptop" Content="💻 Ноутбук" GroupName="PowerMode" Style="{StaticResource MaterialDesignTabRadioButton}" Height="36" FontSize="13" FontWeight="Medium"/>
                                        </UniformGrid>
                                    </Border>

                                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                                        <CheckBox x:Name="CheckCustomPower" Content="Игровой план питания" IsChecked="True" DockPanel.Dock="Left" FontSize="14" FontWeight="Medium" ToolTip="Автоматически создает и применяет максимальный план электропитания при запуске игры, чтобы избежать троттлинга." VerticalAlignment="Center"/>
                                        <Button Click="BtnDeletePlan_Click" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" DockPanel.Dock="Right" ToolTip="Удалить созданный игровой план из системы Windows." Foreground="{DynamicResource MaterialDesignBody}" Opacity="0.6">
                                            <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                                        </Button>
                                    </DockPanel>

                                    <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,0,0,20"/>

                                    <TextBlock Text="ПАРАМЕТРЫ ДВИЖКА" Style="{StaticResource LabelStyle}"/>
                                    <CheckBox x:Name="CheckNoLog" Content="Отключить логи (-nolog)" IsChecked="True" Margin="0,0,0,16" FontSize="14" FontWeight="Medium" ToolTip="Отключает запись логов Unity в фоновом режиме. Это снижает нагрузку на жесткий диск и процессор."/>
                                    <CheckBox x:Name="CheckSingleInstance" Content="Один экземпляр" IsChecked="True" Margin="0,0,0,16" FontSize="14" FontWeight="Medium" ToolTip="Запрещает запуск нескольких копий игры одновременно (-single-instance)."/>
                                    <CheckBox x:Name="CheckNoGfxJobs" Content="Отключить GFX Jobs" IsChecked="False" FontSize="14" FontWeight="Medium" ToolTip="Иногда решает проблему крашей или черного экрана на слабых и старых процессорах (-dcgnt)."/>
                                    <CheckBox x:Name="CheckNoVR" Content="Отключить VR модули (-vrmode none)" IsChecked="True" Margin="0,16,0,0" FontSize="14" FontWeight="Medium" ToolTip="Запрещает движку искать устройства виртуальной реальности в фоне. Экономит ресурсы процессора."/>
                                    <CheckBox x:Name="CheckDirectRender" Content="Прямой рендер графики" IsChecked="False" Margin="0,16,0,0" FontSize="14" FontWeight="Medium" ToolTip="Заставляет графику считаться в один поток (-force-gfx-direct). Включать ТОЛЬКО если игра сильно лагает на старом/слабом 2-4 ядерном процессоре."/>
                                    <CheckBox x:Name="CheckForceDiscreteGPU" Content="Форсировать дискретную GPU" IsChecked="False" Margin="0,16,0,0" FontSize="14" FontWeight="Medium" ToolTip="Указывает движку принудительно использовать видеокарту №1 (-adapter 1). Помогает на ноутбуках, если игра ошибочно запускается на встроенной графике Intel/AMD."/>
                                    
                                    <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,16,0,20"/>
                                    
                                    <TextBlock Text="ОПТИМИЗАЦИЯ WINDOWS" Style="{StaticResource LabelStyle}"/>
                                    <CheckBox x:Name="CheckDisableFSO" Content="Отключить оптимизацию во весь экран" IsChecked="True" Margin="0,0,0,16" FontSize="14" FontWeight="Medium" ToolTip="Блокирует невидимую рамку Windows поверх игры. Кардинально снижает Input Lag (задержку мыши)."/>
                                    <CheckBox x:Name="CheckDisableDPI" Content="Отключить масштабирование DPI" IsChecked="True" Margin="0,0,0,0" FontSize="14" FontWeight="Medium" ToolTip="Гарантирует идеальную резкость картинки (пиксель в пиксель) и правильную работу сенсы мыши, игнорируя масштаб Windows (125%, 150% и т.д.)."/>
                                    <CheckBox x:Name="CheckHighTimer" Content="Системный таймер 0.5 мс" IsChecked="True" Margin="0,16,0,0" FontSize="14" FontWeight="Medium" ToolTip="Переводит ядро Windows в режим высокой точности. Уменьшает системную задержку и делает график Frame Time идеально ровным."/>
                                    <CheckBox x:Name="CheckThreadedGPU" Content="Многопоточность драйвера GPU" IsChecked="True" Margin="0,16,0,0" FontSize="14" FontWeight="Medium" ToolTip="Принудительно заставляет драйвер видеокарты использовать все потоки CPU для подготовки кадров. Помогает загрузить GPU на 100%."/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0" Padding="32,20" Background="{DynamicResource MaterialDesignCardBackground}">
                <Grid>
                    <Button x:Name="BtnSave" Click="BtnSave_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource MaterialDesignBody}" Opacity="0.8" HorizontalAlignment="Left" Padding="16,10" Height="46">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="СОХРАНИТЬ" FontSize="14" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnLaunch" Click="BtnLaunch_Click" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource MaterialDesignDivider}" Background="Transparent" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,16,0" Padding="24,10" Height="46" materialDesign:ButtonAssist.CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayOutline" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="СТАНДАРТНЫЙ ВХОД" FontSize="14" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnLaunchQuick" Click="BtnLaunchQuick_Click" Style="{StaticResource PlayButtonStyle}" BorderThickness="0" Padding="32,10" Height="46" materialDesign:ButtonAssist.CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="RocketLaunch" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ИГРАТЬ С НАСТРОЙКАМИ" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:DialogHost>
</Window>